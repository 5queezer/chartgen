# Base URL for chartgen's MCP + OAuth endpoints.
# In dev this is optional: Vite proxies /mcp, /sse, /register, /authorize,
# /token, /.well-known/* to http://localhost:9315, so the app can leave
# this unset and hit same-origin paths.
# In production builds, set this to the deployed chartgen origin.
VITE_CHARTGEN_BASE_URL=http://localhost:9315
